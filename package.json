{
  "name": "corporate-blog",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "node scripts/run-lint.mjs",
    "test": "vitest run",
    "check:package-json": "node scripts/check-package-json.mjs",
    "check:deps": "node scripts/check-deps.mjs",
    "check:conflicts": "bash scripts/check-conflict-markers.sh",
    "premerge": "npm run check:conflicts && npm run check:package-json && npm test && npm run lint",
    "build:netlify": "npm run check:package-json && npm run check:deps && npm run check:conflicts && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "next": "15.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "^22.13.9",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.21.0",
    "eslint-config-next": "15.2.3",
    "prisma": "^6.6.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9",
    "tsx": "^4.20.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
